---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const allReviews = await getCollection('reviews');

const VERDICT_ORDER = ['adopt', 'adapt', 'watch', 'catalog', 'skip'] as const;
type Verdict = typeof VERDICT_ORDER[number];

const VERDICT_LABEL: Record<Verdict, string> = {
  adopt:   'Adopt',
  adapt:   'Adapt',
  watch:   'Watch',
  catalog: 'Catalog',
  skip:    'Skip',
};

const grouped = VERDICT_ORDER.reduce((acc, v) => {
  acc[v] = allReviews
    .filter(r => r.data.verdict === v)
    .sort((a, b) => b.data.date_evaluated.getTime() - a.data.date_evaluated.getTime());
  return acc;
}, {} as Record<Verdict, typeof allReviews>);

function formatDate(d: Date) {
  return d.toLocaleDateString('en-GB', { year: 'numeric', month: 'short', day: 'numeric' });
}

function slug(id: string) {
  return id.replace(/\.mdx?$/, '');
}
---
<Base title="Resource Library">
  <div class="container">
    <div class="intro">
      <h1 class="intro-title">Resource Library</h1>
      <p class="intro-body">
        A curated log of AI tools, methodologies, and patterns — each evaluated for fit
        against <a href="https://www.gsarigiannidis.gr/claude-code-obsidian-ai/" target="_blank" rel="noopener noreferrer">my specific workflow</a> built around Claude Code and Obsidian.
        Every entry has a verdict and documented reasoning, not just a description.
        The goal is a record of what was considered and why, not a link dump.
      </p>
    </div>

    <div class="how-it-works">
      <div class="steps-grid">
        <div class="step">
          <div class="step-header">
            <span class="step-number">1</span>
            <h3 class="step-title">Clip the resource</h3>
          </div>
          <p class="step-desc">Anything worth evaluating gets clipped from the browser using the Obsidian Web Clipper, which drops it into a temporary inbox folder in the vault.</p>
          <img src="/images/web-clipper.png" alt="Obsidian Web Clipper capturing a resource" class="step-image zoomable" />
        </div>
        <div class="step">
          <div class="step-header">
            <span class="step-number">2</span>
            <h3 class="step-title">Claude evaluates it</h3>
          </div>
          <p class="step-desc">Trigger Claude Code to evaluate the clip — manually in a chat session, or automatically via a cron job or any other automation you wire up. Claude reads the resource, applies a structured evaluation framework, and writes a verdict file.</p>
        </div>
        <div class="step">
          <div class="step-header">
            <span class="step-number">3</span>
            <h3 class="step-title">Review appears in the vault</h3>
          </div>
          <p class="step-desc">The finished evaluation lands in the reviews folder — verdict, reasoning, conditions for fit — ready to read whenever, and automatically published here on the next push.</p>
          <img src="/images/obsidian-vault.png" alt="Finished review in the Obsidian vault" class="step-image zoomable" />
        </div>
      </div>
    </div>

    <div class="playbook-links">
      <a href="https://github.com/gsarig/ai-playbooks/blob/main/playbooks/resource-library/.claude/skills/evaluate-resource/SKILL.md" target="_blank" rel="noopener noreferrer" class="btn btn-secondary">View the skill</a>
      <a href="https://github.com/gsarig/ai-playbooks/tree/main/playbooks/resource-library" target="_blank" rel="noopener noreferrer" class="btn btn-primary">View the playbook</a>
    </div>

    {VERDICT_ORDER.filter(v => grouped[v].length > 0).map(v => (
      <section class="verdict-group">
        <div class="section-heading">
          <span class={`verdict verdict-${v}`}>{VERDICT_LABEL[v]}</span>
          <h2>{grouped[v].length} {grouped[v].length === 1 ? 'entry' : 'entries'}</h2>
        </div>
        <div class="cards">
          {grouped[v].map(review => (
            <a href={`/reviews/${slug(review.id)}`} class="card">
              <div>
                <div class="card-title">{review.data.title}</div>
                <div class="card-meta">by {review.data.author}</div>
                <div class="tags">
                  {review.data.tags.map(tag => <span class="tag">{tag}</span>)}
                </div>
              </div>
              <div class="card-date">{formatDate(review.data.date_evaluated)}</div>
            </a>
          ))}
        </div>
      </section>
    ))}
  </div>
  <div id="modal" class="modal" aria-hidden="true">
    <button class="modal-close" id="modal-close" aria-label="Close">&times;</button>
    <img id="modal-img" src="" alt="" class="modal-img" />
  </div>
</Base>

<script>
  const modal    = document.getElementById('modal')!;
  const modalImg = document.getElementById('modal-img') as HTMLImageElement;
  const closeBtn = document.getElementById('modal-close')!;

  document.querySelectorAll<HTMLImageElement>('.zoomable').forEach(img => {
    img.style.cursor = 'zoom-in';
    img.addEventListener('click', () => {
      modalImg.src = img.src;
      modalImg.alt = img.alt;
      modal.classList.add('is-open');
      modal.setAttribute('aria-hidden', 'false');
    });
  });

  function closeModal() {
    modal.classList.remove('is-open');
    modal.setAttribute('aria-hidden', 'true');
  }

  closeBtn.addEventListener('click', closeModal);
  modal.addEventListener('click', e => { if (e.target === modal) closeModal(); });
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });
</script>
